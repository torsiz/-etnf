            img = Image.open(image_path)
            img = img.resize((80, 80), Image.Resampling.LANCZOS)
            self.photo = ctk.CTkImage(light_image=img, dark_image=img, size=(80, 80))
            self.image_label = ctk.CTkLabel(self.image_frame, image=self.photo, text="")
            self.image_label.pack(expand=True)
        except:
            self.image_label = ctk.CTkLabel(self.image_frame, text="📦", font=("Arial", 30))
            self.image_label.pack(expand=True)
        
        # Центральная часть
        self.info_frame = ctk.CTkFrame(self, fg_color="transparent")
        self.info_frame.pack(side="left", fill="both", expand=True, padx=10, pady=10)
        
        self.name_label = ctk.CTkLabel(self.info_frame, text=product_data['name'], 
                                       font=ctk.CTkFont(size=14, weight="bold"), anchor="w")
        self.name_label.pack(anchor="w")
        
        desc_text = product_data['description'][:60] + "..." if len(product_data['description']) > 60 else product_data['description']
        self.desc_label = ctk.CTkLabel(self.info_frame, text=desc_text, 
                                       font=ctk.CTkFont(size=11), anchor="w", wraplength=200)
        self.desc_label.pack(anchor="w", pady=(5, 0))
        
        # Правая часть - цена
        self.price_frame = ctk.CTkFrame(self, fg_color="transparent")
        self.price_frame.pack(side="right", padx=10, pady=10)
        
        final_price = product_data['price'] * (1 - product_data['discount'] / 100)
        
        self.current_price = ctk.CTkLabel(self.price_frame, text=f"{final_price:.2f} ₽", 
                                          font=ctk.CTkFont(size=16, weight="bold"), text_color="#359A85")
        self.current_price.pack(anchor="e")
        
        if product_data['discount'] > 0:
            self.old_price = ctk.CTkLabel(self.price_frame, text=f"{product_data['price']:.2f} ₽", 
                                          font=ctk.CTkFont(size=11), text_color="gray")
            self.old_price.pack(anchor="e")
            
            # Бейдж со скидкой
            self.discount_badge = ctk.CTkLabel(self.price_frame, text=f"-{product_data['discount']:.0f}%", 
                                               font=ctk.CTkFont(size=10, weight="bold"), 
                                               text_color="white", fg_color="red", corner_radius=10, width=40)
            self.discount_badge.pack(anchor="e", pady=(2, 0))
    
    def on_enter(self, event=None):
        self.configure(border_color="#359A85", border_width=2)
    
    def on_leave(self, event=None):
        self.configure(border_color="gray70", border_width=1)
    
    def highlight_selected(self, is_selected):
        if is_selected:
            self.configure(border_color="#ff9800", border_width=3)
        else:
            self.configure(border_color="gray70", border_width=1)


class CartWindow:
    """Окно корзины."""
    
    def __init__(self, parent, user_id, cart_items, update_callback):
        self.parent = parent
        self.user_id = user_id
        self.cart_items = cart_items
        self.update_callback = update_callback
        
        self.window = ctk.CTkToplevel(parent)
        self.window.title("Корзина — ТехноМаркет")
        self.window.geometry("900x550")
        self.window.grab_set()
        
        self.create_ui()
        self.refresh_table()
    
    def create_ui(self):
        # Шапка
        header = ctk.CTkFrame(self.window, height=60, corner_radius=0, fg_color="#359A85")
        header.pack(fill="x")
        ctk.CTkLabel(header, text="Корзина", font=ctk.CTkFont(size=24, weight="bold"), 
                    text_color="white").pack(pady=15)
        
        # Основная область с таблицей
        self.table_frame = ctk.CTkFrame(self.window, fg_color="transparent")
        self.table_frame.pack(fill="both", expand=True, padx=20, pady=10)
        
        # Нижняя панель
        bottom_frame = ctk.CTkFrame(self.window, height=70, corner_radius=0)
        bottom_frame.pack(fill="x", side="bottom")
        
        self.total_label = ctk.CTkLabel(bottom_frame, text="Общая сумма заказов: 0.00 ₽", 
                                       font=ctk.CTkFont(size=18, weight="bold"))
        self.total_label.pack(side="left", padx=20)
        
        clear_btn = ctk.CTkButton(bottom_frame, text="Очистить корзину", command=self.clear_cart, 
                                 fg_color="gray", width=150)
        clear_btn.pack(side="right", padx=10, pady=15)
        
        order_btn = ctk.CTkButton(bottom_frame, text="Оформить заказ", command=self.checkout, 
                                 fg_color="#359A85", width=150)
        order_btn.pack(side="right", padx=10, pady=15)
    
    def refresh_table(self):
        """Обновление таблицы товаров."""
        # Очистка
        for widget in self.table_frame.winfo_children():
            widget.destroy()
        
        if not self.cart_items:
            empty_label = ctk.CTkLabel(self.table_frame, text="Корзина пуста", 
                                       font=ctk.CTkFont(size=20), text_color="gray")
            empty_label.pack(expand=True, pady=50)
            self.total_label.configure(text="Общая сумма заказов: 0.00 ₽")
            return
        
        # Заголовки
        headers_frame = ctk.CTkFrame(self.table_frame, fg_color="transparent")
        headers_frame.pack(fill="x", pady=(0, 5))
        
        headers = ["Товар", "Описание", "Цена", "Кол-во", "Сумма", ""]
        widths = [200, 250, 100, 80, 120, 80]
        for i, (header, width) in enumerate(zip(headers, widths)):
            lbl = ctk.CTkLabel(headers_frame, text=header, font=ctk.CTkFont(weight="bold"), width=width)
            lbl.grid(row=0, column=i, padx=5, sticky="w")
        
        total_sum = 0
        self.row_widgets = []
        
        for idx, (product_id, quantity, price) in enumerate(self.cart_items):
            product = get_product_by_id(product_id)
            if not product:
                continue
            
            item_sum = price * quantity
            total_sum += item_sum
            
            row_frame = ctk.CTkFrame(self.table_frame, fg_color="transparent")
            row_frame.pack(fill="x", pady=2)
            
            # Название
            ctk.CTkLabel(row_frame, text=product['name'][:30], width=200, anchor="w").grid(row=0, column=0, padx=5)
            # Описание
            desc = product['description'][:35]
            ctk.CTkLabel(row_frame, text=desc, width=250, anchor="w").grid(row=0, column=1, padx=5)
            # Цена
            ctk.CTkLabel(row_frame, text=f"{price:.2f} ₽", width=100, anchor="w").grid(row=0, column=2, padx=5)
            
            # Количество с возможностью изменения
            qty_frame = ctk.CTkFrame(row_frame, fg_color="transparent")
            qty_frame.grid(row=0, column=3, padx=5)
            
            def decrease(q_idx, p_id, cur_qty):
                if cur_qty > 1:
                    self.cart_items[q_idx] = (p_id, cur_qty - 1, price)
                    self.refresh_table()
                    self.update_callback(self.cart_items)
            
            def increase(q_idx, p_id, cur_qty):
                self.cart_items[q_idx] = (p_id, cur_qty + 1, price)
                self.refresh_table()
                self.update_callback(self.cart_items)
            
            minus_btn = ctk.CTkButton(qty_frame, text="-", width=30, height=30, 
                                     command=lambda i=idx, pid=product_id, q=quantity: decrease(i, pid, q))
            minus_btn.pack(side="left", padx=2)
            
            qty_label = ctk.CTkLabel(qty_frame, text=str(quantity), width=40, font=ctk.CTkFont(size=14))
            qty_label.pack(side="left", padx=5)
            
            plus_btn = ctk.CTkButton(qty_frame, text="+", width=30, height=30,
                                     command=lambda i=idx, pid=product_id, q=quantity: increase(i, pid, q))
            plus_btn.pack(side="left", padx=2)
            
            # Сумма
            ctk.CTkLabel(row_frame, text=f"{item_sum:.2f} ₽", width=120, anchor="w").grid(row=0, column=4, padx=5)
            
            # Кнопка удаления
            del_btn = ctk.CTkButton(row_frame, text="🗑️", width=50, height=30, fg_color="red",
                                   command=lambda i=idx: self.remove_item(i))
            del_btn.grid(row=0, column=5, padx=5)
        
        self.total_label.configure(text=f"Общая сумма заказов: {total_sum:.2f} ₽")
    
    def remove_item(self, index):
        del self.cart_items[index]
        self.refresh_table()
        self.update_callback(self.cart_items)
    
    def clear_cart(self):
        if messagebox.askyesno("Очистка", "Вы уверены, что хотите очистить корзину?"):
            self.cart_items.clear()
            self.refresh_table()
            self.update_callback(self.cart_items)
    
    def checkout(self):
        if not self.cart_items:
            messagebox.showwarning("Оформление", "Корзина пуста")
            return
        
        if messagebox.askyesno("Оформление", "Подтвердить заказ?"):
            if save_order(self.user_id, self.cart_items):
                messagebox.showinfo("Успех", "Заказ оформлен! Спасибо за покупку!")
                self.cart_items.clear()
                self.refresh_table()
                self.update_callback(self.cart_items)
                self.window.destroy()
            else:
                messagebox.showerror("Ошибка", "Не удалось сохранить заказ")


