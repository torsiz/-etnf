def init_db():
    """Инициализация базы данных: создание таблиц и заполнение тестовыми данными."""
    conn = sqlite3.connect(DATABASE_NAME)
    cursor = conn.cursor()

    # Таблица пользователей
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password_hash TEXT NOT NULL,
            failed_attempts INTEGER DEFAULT 0,
            is_blocked BOOLEAN DEFAULT 0,
            blocked_until TEXT DEFAULT NULL
        )
    ''')

    # Таблица товаров
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS products (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            description TEXT,
            price REAL NOT NULL,
            discount REAL DEFAULT 0,
            image_path TEXT
        )
    ''')

    # Таблица заказов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS orders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            total_sum REAL NOT NULL,
            order_date TEXT NOT NULL,
            FOREIGN KEY (user_id) REFERENCES users (id)
        )
    ''')

    # Таблица позиций заказа
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS order_items (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_id INTEGER NOT NULL,
            product_id INTEGER NOT NULL,
            quantity INTEGER NOT NULL,
            price_at_time REAL NOT NULL,
            FOREIGN KEY (order_id) REFERENCES orders (id),
            FOREIGN KEY (product_id) REFERENCES products (id)
        )
    ''')

    # Заполнение тестовыми товарами, если таблица пуста
    cursor.execute("SELECT COUNT(*) FROM products")
    if cursor.fetchone()[0] == 0:
        test_products = [
            ("Игровая мышь Logitech G502", "Беспроводная мышь с RGB подсветкой, 25K DPI", 8990.00, 15, "mouse.png"),
            ("Механическая клавиатура HyperX", "Red Switch, полная раскладка, RGB", 12500.00, 25, "keyboard.png"),
            ("Монитор 27\" ASUS TUF", "IPS, 165Hz, 1ms, G-Sync", 28990.00, 10, "monitor.png"),
            ("Коврик для мыши Razer", "Большой размер, прошивка края", 2500.00, 0, "pad.png"),
            ("USB Hub 4 порта", "USB 3.0, алюминиевый корпус", 1200.00, 5, "hub.png"),
            ("Наушники HyperX Cloud II", "7.1 виртуальный звук, шумоподавление", 11490.00, 20, "headphones.png"),
            ("Веб-камера Logitech C922", "1080p 30fps, автофокус", 8990.00, 8, "webcam.png"),
            ("SSD Samsung 1TB", "NVMe M.2, чтение 7000MB/s", 12990.00, 12, "ssd.png"),
        ]
        cursor.executemany("INSERT INTO products (name, description, price, discount, image_path) VALUES (?,?,?,?,?)", test_products)

    # Создание тестового пользователя
    hashed = bcrypt.hashpw("admin".encode('utf-8'), bcrypt.gensalt())
    try:
        cursor.execute("INSERT INTO users (username, password_hash) VALUES (?, ?)", ("admin", hashed))
    except sqlite3.IntegrityError:
        pass

    # Добавляем ещё одного тестового пользователя
    hashed2 = bcrypt.hashpw("user".encode('utf-8'), bcrypt.gensalt())
    try:
        cursor.execute("INSERT INTO users (username, password_hash) VALUES (?, ?)", ("user", hashed2))
    except sqlite3.IntegrityError:
        pass

    conn.commit()
    conn.close()


def register_user(username: str, password: str) -> Tuple[bool, str]:
    """Регистрация нового пользователя."""
    if len(password) < 4:
        return False, "Пароль должен содержать минимум 4 символа"
    
    try:
        hashed = bcrypt.hashpw(password.encode('utf-8'), bcrypt.gensalt())
        conn = sqlite3.connect(DATABASE_NAME)
        cursor = conn.cursor()
        cursor.execute("INSERT INTO users (username, password_hash) VALUES (?, ?)", (username, hashed))
        conn.commit()
        conn.close()
        return True, "Регистрация успешна"
    except sqlite3.IntegrityError:
        return False, "Пользователь с таким логином уже существует"


def authenticate_user(username: str, password: str) -> Tuple[bool, str, Optional[int]]:
    """
    Аутентификация с блокировкой после 3 неудачных попыток.
    Возвращает: (успех, сообщение, id_пользователя)
    """
    conn = sqlite3.connect(DATABASE_NAME)
    cursor = conn.cursor()
    
    cursor.execute("SELECT id, password_hash, failed_attempts, is_blocked, blocked_until FROM users WHERE username = ?", (username,))
    user = cursor.fetchone()
    
    if not user:
        conn.close()
        return False, "Пользователь не найден", None
    
    user_id, hashed, attempts, blocked, blocked_until = user
    
    # Проверка временной блокировки
    if blocked and blocked_until:
        if datetime.now().isoformat() > blocked_until:
            # Снимаем блокировку
            cursor.execute("UPDATE users SET is_blocked = 0, failed_attempts = 0, blocked_until = NULL WHERE id = ?", (user_id,))
            conn.commit()
            blocked = False
        else:
            conn.close()
            return False, f"Аккаунт заблокирован до {blocked_until[:19]}", None
    
    if blocked:
        conn.close()
        return False, "Аккаунт заблокирован. Обратитесь к администратору", None
    
    # Проверка пароля
    if bcrypt.checkpw(password.encode('utf-8'), hashed):
        cursor.execute("UPDATE users SET failed_attempts = 0 WHERE id = ?", (user_id,))
        conn.commit()
        conn.close()
        return True, "Успешный вход", user_id
    else:
        attempts += 1
        if attempts >= 3:
            # Блокировка на 5 минут
            block_time = datetime.now().isoformat()
            cursor.execute("UPDATE users SET failed_attempts = ?, is_blocked = 1, blocked_until = ? WHERE id = ?", 
                          (attempts, block_time, user_id))
            conn.commit()
            conn.close()
            return False, "Превышено количество попыток. Аккаунт заблокирован на 5 минут", None
        else:
            cursor.execute("UPDATE users SET failed_attempts = ? WHERE id = ?", (attempts, user_id))
            conn.commit()
            conn.close()
            return False, f"Неверный пароль. Осталось попыток: {3 - attempts}", None


def get_products(search_term: str = "", discount_filter: str = "Без сортировки") -> List[Dict[str, Any]]:
    """Получение списка товаров с фильтрацией."""
    conn = sqlite3.connect(DATABASE_NAME)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    
    query = "SELECT id, name, description, price, discount, image_path FROM products WHERE 1=1"
    params = []
    
    if search_term:
        query += " AND (name LIKE ? OR description LIKE ?)"
        params.extend([f"%{search_term}%", f"%{search_term}%"])
    
    if discount_filter == "от 0% до 14.99%":
        query += " AND discount BETWEEN 0 AND 14.99"
    elif discount_filter == "от 15% до 24.99%":
        query += " AND discount BETWEEN 15 AND 24.99"
    elif discount_filter == "более 25%":
        query += " AND discount > 25"
    
    cursor.execute(query, params)
    products = [dict(row) for row in cursor.fetchall()]
    conn.close()
    return products


def get_product_by_id(product_id: int) -> Optional[Dict[str, Any]]:
    """Получение товара по ID."""
    conn = sqlite3.connect(DATABASE_NAME)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    cursor.execute("SELECT id, name, description, price, discount, image_path FROM products WHERE id = ?", (product_id,))
    product = cursor.fetchone()
    conn.close()
    return dict(product) if product else None


def save_order(user_id: int, cart_items: List[Tuple[int, int, float]]) -> bool:
    """Сохранение заказа в БД."""
    try:
        conn = sqlite3.connect(DATABASE_NAME)
        cursor = conn.cursor()
        
        total_sum = sum(qty * price for _, qty, price in cart_items)
        order_date = datetime.now().isoformat()
        
        cursor.execute(
            "INSERT INTO orders (user_id, total_sum, order_date) VALUES (?, ?, ?)",
            (user_id, total_sum, order_date)
        )
        order_id = cursor.lastrowid
        
        for product_id, quantity, price in cart_items:
            cursor.execute(
                "INSERT INTO order_items (order_id, product_id, quantity, price_at_time) VALUES (?, ?, ?, ?)",
                (order_id, product_id, quantity, price)
            )
        
        conn.commit()
        conn.close()
        return True
    except Exception as e:
        print(f"Ошибка: {e}")
        return False


