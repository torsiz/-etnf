        self.search_entry.bind("<Return>", lambda e: self.load_products())
        
        self.filter_option = ctk.CTkOptionMenu(self.filter_frame, 
                                              values=["Без сортировки", "от 0% до 14.99%", "от 15% до 24.99%", "более 25%"],
                                              width=180, height=40)
        self.filter_option.pack(side="left", padx=(0, 10))
        self.filter_option.set("Без сортировки")
        
        self.search_btn = ctk.CTkButton(self.filter_frame, text="Найти", width=120, height=40,
                                       command=self.load_products, fg_color="#359A85")
        self.search_btn.pack(side="left")
        
        # Область с товарами (скроллируемая)
        self.products_frame = ctk.CTkScrollableFrame(self, label_text="📦 Каталог товаров")
        self.products_frame.pack(fill="both", expand=True, padx=20, pady=(0, 10))
        
        # Нижняя панель
        self.footer_frame = ctk.CTkFrame(self, height=55, corner_radius=0)
        self.footer_frame.pack(fill="x", side="bottom")
        self.footer_frame.pack_propagate(False)
        
        self.counter_label = ctk.CTkLabel(self.footer_frame, text="Показано 0 товаров", 
                                         font=ctk.CTkFont(size=13))
        self.counter_label.pack(side="left", padx=20)
        
        self.cart_btn = ctk.CTkButton(self.footer_frame, text="🛒 Корзина (0)", width=180, height=40,
                                     command=self.open_cart, fg_color="#359A85", font=ctk.CTkFont(size=14, weight="bold"))
        self.cart_btn.pack(side="right", padx=20)
    
    def load_products(self):
        """Загрузка и отображение товаров."""
        for widget in self.products_frame.winfo_children():
            widget.destroy()
        
        search_text = self.search_entry.get()
        filter_value = self.filter_option.get()
        
        products = get_products(search_text, filter_value)
        
        self.counter_label.configure(text=f"Показано {len(products)} товаров")
        
        if not products:
            empty_label = ctk.CTkLabel(self.products_frame, text="Товары не найдены", 
                                       font=ctk.CTkFont(size=18), text_color="gray")
            empty_label.pack(expand=True, pady=50)
            return
        
        # Отображение в виде сетки
        cols = 2
        for i, product in enumerate(products):
            row = i // cols
            col = i % cols
            
            card = ProductCard(
                self.products_frame, 
                product,
                add_to_cart_callback=self.add_to_cart,
                select_callback=self.select_product,
                width=500
            )
            card.grid(row=row, column=col, padx=10, pady=10, sticky="nsew")
            
            # Контекстное меню
            card.bind("<Button-3>", lambda e, p=product: self.show_context_menu(e, p))
            for child in card.winfo_children():
                child.bind("<Button-3>", lambda e, p=product: self.show_context_menu(e, p))
        
        for i in range(cols):
            self.products_frame.grid_columnconfigure(i, weight=1)
    
    def select_product(self, product_id):
        """Выбор товара с подсветкой."""
        self.selected_product_id = product_id
        for widget in self.products_frame.winfo_children():
            if isinstance(widget, ProductCard):
                widget.highlight_selected(widget.product_data['id'] == product_id)
    
    def show_context_menu(self, event, product):
        """Контекстное меню по правому клику."""
        menu = ctk.CTkMenu(self, tearoff=False)
        menu.add_command(label="🔄 Обновить", command=self.load_products)
        menu.add_command(label="➕ Добавить в корзину", command=lambda: self.add_to_cart(product))
        menu.post(event.x_root, event.y_root)
    
    def add_to_cart(self, product_data):
        """Добавление товара в корзину."""
        product_id = product_data['id']
        final_price = product_data['price'] * (1 - product_data['discount'] / 100)
        
        for i, (pid, qty, price) in enumerate(self.cart_items):
            if pid == product_id:
                self.cart_items[i] = (pid, qty + 1, price)
                break
        else:
            self.cart_items.append((product_id, 1, final_price))
        
        total_items = sum(qty for _, qty, _ in self.cart_items)
        self.cart_btn.configure(text=f"🛒 Корзина ({total_items})")
        
        messagebox.showinfo("Корзина", f"Товар '{product_data['name']}' добавлен в корзину")
    
    def open_cart(self):
        """Открытие окна корзины."""
        if not self.cart_items:
            messagebox.showinfo("Корзина", "Корзина пуста. Добавьте товары через контекстное меню")
            return
        
        CartWindow(self, self.user_id, self.cart_items, self.update_cart_callback)
    
    def update_cart_callback(self, new_cart):
        """Обновление состояния корзины."""
        self.cart_items = new_cart
        total_items = sum(qty for _, qty, _ in self.cart_items)
        self.cart_btn.configure(text=f"🛒 Корзина ({total_items})")
    
    def toggle_theme(self):
        """Переключение цветовой темы."""
        current = ctk.get_appearance_mode()
        if current == "Light":
            ctk.set_appearance_mode("Dark")
            self.theme_btn.configure(text="☀️")
        else:
            ctk.set_appearance_mode("Light")
            self.theme_btn.configure(text="🌙")
    
    def logout(self):
        """Выход из аккаунта."""
        if messagebox.askyesno("Выход", "Вы уверены, что хотите выйти?"):
            self.destroy()
            show_login_window()


# ==================== ОКНО АВТОРИЗАЦИИ ====================

def show_login_window():
    """Окно входа и регистрации."""
    login_window = ctk.CTk()
    login_window.title("Авторизация — ТехноМаркет")
    login_window.geometry("450x600")
    login_window.resizable(False, False)
    
    # Центрирование
    login_window.update_idletasks()
    x = (login_window.winfo_screenwidth() // 2) - (450 // 2)
    y = (login_window.winfo_screenheight() // 2) - (600 // 2)
    login_window.geometry(f"450x600+{x}+{y}")
    
    # Фрейм с формой
    main_frame = ctk.CTkFrame(login_window, corner_radius=20)
    main_frame.pack(expand=True, fill="both", padx=30, pady=30)
    
    # Логотип
    ctk.CTkLabel(main_frame, text="🛍️", font=ctk.CTkFont(size=50)).pack(pady=(20, 0))
    ctk.CTkLabel(main_frame, text="ТехноМаркет", font=ctk.CTkFont(size=28, weight="bold"), 
                text_color="#359A85").pack(pady=(0, 20))
    
    # Поля ввода
    username_entry = ctk.CTkEntry(main_frame, placeholder_text="Логин", width=280, height=45, font=ctk.CTkFont(size=14))
    username_entry.pack(pady=10)
    
    password_entry = ctk.CTkEntry(main_frame, placeholder_text="Пароль", show="*", width=280, height=45, font=ctk.CTkFont(size=14))
    password_entry.pack(pady=10)
    
    status_label = ctk.CTkLabel(main_frame, text="", font=ctk.CTkFont(size=12))
    status_label.pack(pady=5)
    
    def do_login():
        username = username_entry.get().strip()
        password = password_entry.get()
        
        if not username or not password:
            status_label.configure(text="Заполните все поля", text_color="red")
            return
        
        success, msg, user_id = authenticate_user(username, password)
        if success:
            status_label.configure(text=msg, text_color="green")
            login_window.destroy()
            app = MainApplication(user_id, username)
            app.mainloop()
        else:
            status_label.configure(text=msg, text_color="red")
    
    def do_register():
        username = username_entry.get().strip()
        password = password_entry.get()
        
        if not username or not password:
            status_label.configure(text="Заполните все поля", text_color="red")
            return
        
        success, msg = register_user(username, password)
        if success:
            status_label.configure(text=msg + "! Теперь войдите", text_color="green")
            username_entry.delete(0, 'end')
            password_entry.delete(0, 'end')
        else:
            status_label.configure(text=msg, text_color="red")
    
    ctk.CTkButton(main_frame, text="Войти", command=do_login, width=200, height=45, 
                 font=ctk.CTkFont(size=14, weight="bold"), fg_color="#359A85").pack(pady=15)
    
    ctk.CTkButton(main_frame, text="Зарегистрироваться", command=do_register, width=200, height=40,
                 font=ctk.CTkFont(size=13), fg_color="gray", hover_color="#666").pack(pady=5)
    
    # Информация о тестовых пользователях
    info_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    info_frame.pack(pady=(20, 0))
    ctk.CTkLabel(info_frame, text="Тестовые аккаунты:", font=ctk.CTkFont(size=11), text_color="gray").pack()
    ctk.CTkLabel(info_frame, text="admin / admin | user / user", font=ctk.CTkFont(size=11), text_color="gray").pack()
    
    login_window.mainloop()


# ==================== ТОЧКА ВХОДА ====================

if __name__ == "__main__":
    init_db()
    show_login_window()


