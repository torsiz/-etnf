class ProductCard(ctk.CTkFrame):
    """Карточка товара в виде плитки."""
    
    def __init__(self, master, product_data, add_to_cart_callback, select_callback, **kwargs):
        super().__init__(master, **kwargs)
        self.product_data = product_data
        self.add_to_cart_callback = add_to_cart_callback
        self.select_callback = select_callback
        self.configure(corner_radius=10, border_width=1, border_color="gray70")
        
        # Подсветка при наведении
        self.bind("<Enter>", self.on_enter)
        self.bind("<Leave>", self.on_leave)
        self.bind("<Button-1>", lambda e: self.select_callback(product_data['id']))
        
        # Левая часть - изображение
        self.image_frame = ctk.CTkFrame(self, width=90, height=90, fg_color="transparent")
        self.image_frame.pack(side="left", padx=10, pady=10)
        self.image_frame.pack_propagate(False)
        
        # Загрузка изображения
