    def toggle_password(self):
        """Показать/скрыть пароль"""
        if self.show_password_var.get():
            self.password_entry.configure(show="")
        else:
            self.password_entry.configure(show="*")
    
    def login(self):
        """Процесс авторизации с проверкой капчи"""
        username = self.username_entry.get().strip()
        password = self.password_entry.get()
        
        if not username or not password:
            self.status_label.configure(text="Заполните все поля", text_color="red")
            return
        
        # Показ капчи
        captcha = CaptchaDialog(self)
        captcha_result = captcha.show()
        
        if not captcha_result:
            self.status_label.configure(text="Капча не пройдена. Попробуйте снова", text_color="red")
            # Увеличиваем счетчик неудачных попыток
            return
        
        # Аутентификация
        success, msg, role, user_id = authenticate_user(username, password)
        
        if success:
            self.status_label.configure(text=msg, text_color="green")
            self.after(1000, lambda: self.open_main_window(role, username, user_id))
        else:
            self.status_label.configure(text=msg, text_color="red")
    
    def open_main_window(self, role, username, user_id):
        """Открытие основного окна после успешной авторизации"""
        self.withdraw()  # Скрываем окно авторизации
        
        if role == 'admin':
            admin_panel = AdminPanel(self)
            admin_panel.protocol("WM_DELETE_WINDOW", lambda: self.on_child_close(admin_panel))
        else:
            user_panel = UserPanel(self, username, user_id)
            user_panel.protocol("WM_DELETE_WINDOW", lambda: self.on_child_close(user_panel))
    
    def on_child_close(self, child_window):
        """Обработка закрытия дочернего окна"""
        child_window.destroy()
        self.deiconify()  # Показываем окно авторизации
        self.username_entry.delete(0, 'end')
        self.password_entry.delete(0, 'end')
        self.status_label.configure(text="")


