"""
database.py - Модуль для работы с базами данных
Содержит функции для создания таблиц, импорта данных и сложных запросов
"""

import sqlite3
import json
import bcrypt
from datetime import datetime

# ==================== БАЗА ДАННЫХ ПРОИЗВОДСТВА (модули 2 и 3) ====================

PRODUCTION_DB = "production.db"

def init_production_db():
    """Создание всех таблиц для производственной системы (модуль 2)"""
    conn = sqlite3.connect(PRODUCTION_DB)
    cursor = conn.cursor()
    
    # Таблица заказчиков
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS customers (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            inn TEXT UNIQUE,
            phone TEXT,
            email TEXT
        )
    ''')
    
    # Таблица продукции
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS products (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            base_price REAL NOT NULL,
            description TEXT
        )
    ''')
    
    # Таблица материалов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS materials (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            cost_per_unit REAL NOT NULL,
            unit TEXT DEFAULT 'шт'
        )
    ''')
    
    # Таблица спецификаций (нормы расхода материалов на продукцию)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS specifications (
            product_id INTEGER,
            material_id INTEGER,
            norm REAL NOT NULL,
            FOREIGN KEY (product_id) REFERENCES products(id) ON DELETE CASCADE,
            FOREIGN KEY (material_id) REFERENCES materials(id) ON DELETE CASCADE,
            PRIMARY KEY (product_id, material_id)
        )
    ''')
    
    # Таблица заказов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS orders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            customer_id INTEGER,
            order_date TEXT,
            status TEXT DEFAULT 'новый',
            FOREIGN KEY (customer_id) REFERENCES customers(id)
        )
    ''')
    
    # Таблица позиций заказа
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS order_items (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_id INTEGER,
            product_id INTEGER,
            quantity INTEGER NOT NULL,
            FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
            FOREIGN KEY (product_id) REFERENCES products(id)
        )
    ''')
    
    conn.commit()
    conn.close()
    print("✅ База данных production.db инициализирована")

def import_customers_from_json(json_file_path: str):
    """Импорт заказчиков из JSON файла (модуль 2)"""
    try:
        with open(json_file_path, 'r', encoding='utf-8') as f:
            customers = json.load(f)
        
        conn = sqlite3.connect(PRODUCTION_DB)
        cursor = conn.cursor()
        
        # Если передан список, а не объект
        if isinstance(customers, dict) and 'customers' in customers:
            customers = customers['customers']
        
        for customer in customers:
            cursor.execute('''
                INSERT OR REPLACE INTO customers (id, name, inn, phone, email)
                VALUES (?, ?, ?, ?, ?)
            ''', (
                customer.get('id'),
                customer.get('name'),
                customer.get('inn'),
                customer.get('phone', ''),
                customer.get('email', '')
            ))
        
        conn.commit()
        conn.close()
        print(f"✅ Импортировано {len(customers)} заказчиков")
        return True
    except Exception as e:
        print(f"❌ Ошибка импорта: {e}")
        return False

def get_order_total_cost(order_id: int) -> float:
    """
    Модуль 3: Вычисление полной стоимости заказа
    Учитывает количество продукции и стоимость всех материалов по норме расхода
    """
    conn = sqlite3.connect(PRODUCTION_DB)
    cursor = conn.cursor()
    
    query = '''
        SELECT 
            o.id AS order_id,
            c.name AS customer_name,
            oi.product_id,
            p.name AS product_name,
            oi.quantity,
            -- Стоимость материалов для данного продукта
            (
                SELECT SUM(s.norm * m.cost_per_unit)
                FROM specifications s
                JOIN materials m ON s.material_id = m.id
                WHERE s.product_id = oi.product_id
            ) AS material_cost_per_unit,
            -- Общая стоимость заказа по материалам
            oi.quantity * (
                SELECT SUM(s.norm * m.cost_per_unit)
                FROM specifications s
                JOIN materials m ON s.material_id = m.id
                WHERE s.product_id = oi.product_id
            ) AS total_material_cost
        FROM orders o
        JOIN customers c ON o.customer_id = c.id
        JOIN order_items oi ON o.id = oi.order_id
        WHERE o.id = ?
    '''
    
    cursor.execute(query, (order_id,))
    results = cursor.fetchall()
    conn.close()
    
    if results:
        total = sum(row[6] for row in results)  # sum of total_material_cost
        return total
    return 0.0

def get_all_orders_with_cost():
    """Получение всех заказов с их полной стоимостью"""
    conn = sqlite3.connect(PRODUCTION_DB)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    
    cursor.execute("SELECT DISTINCT id, customer_id, order_date, status FROM orders")
    orders = cursor.fetchall()
    
    result = []
    for order in orders:
        total_cost = get_order_total_cost(order['id'])
        result.append({
            'order_id': order['id'],
            'customer_id': order['customer_id'],
            'order_date': order['order_date'],
            'status': order['status'],
            'total_cost': total_cost
        })
    
    conn.close()
    return result

