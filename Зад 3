"""
captcha_puzzle.py - Модуль пазл-капчи для проверки, что пользователь человек
"""

import customtkinter as ctk
from PIL import Image, ImageTk
import random
import os

class PuzzleCaptcha(ctk.CTkToplevel):
    """Окно капчи в виде пазла из 4 фрагментов"""
    
    def __init__(self, parent, callback, image_path="captcha_image.png"):
        """
        parent: родительское окно
        callback: функция, вызываемая с результатом (True/False)
        image_path: путь к изображению для пазла
        """
        super().__init__(parent)
        self.callback = callback
        self.image_path = image_path
        self.selected_piece = None
        self.pieces = []  # хранит позиции (row, col)
        
        self.title("Подтверждение: соберите пазл")
        self.geometry("500x500")
        self.resizable(False, False)
        self.grab_set()  # модальное окно
        
        # Создаем пазл
        self.create_puzzle()
        
        # Кнопка проверки
        self.check_button = ctk.CTkButton(
            self, 
            text="✅ Проверить пазл", 
            command=self.check_puzzle,
            font=ctk.CTkFont(size=14, weight="bold"),
            fg_color="#359A85",
            height=40
        )
        self.check_button.pack(pady=15)
        
        # Инструкция
        self.instruction = ctk.CTkLabel(
            self,
            text="Нажмите на фрагмент, который хотите переместить, затем на место куда переместить",
            font=ctk.CTkFont(size=11),
            text_color="gray"
        )
        self.instruction.pack(pady=5)
    
    def create_puzzle(self):
        """Создание пазла из 4 фрагментов"""
        # Загрузка изображения
        if not os.path.exists(self.image_path):
            # Создаем изображение-заглушку
            self.create_default_image()
        
        try:
            original = Image.open(self.image_path)
            original = original.resize((400, 400), Image.Resampling.LANCZOS)
        except:
            self.create_default_image()
            original = Image.open(self.image_path)
            original = original.resize((400, 400), Image.Resampling.LANCZOS)
        
        # Разрезаем на 4 части (2x2)
        w, h = 200, 200  # размер каждого фрагмента
        self.correct_positions = []
        
        for row in range(2):
            for col in range(2):
                left = col * w
                top = row * h
                right = left + w
                bottom = top + h
                piece = original.crop((left, top, right, bottom))
                self.correct_positions.append((row, col))
        
        # Создаем перемешанный список фрагментов
        self.pieces_positions = self.correct_positions.copy()
        random.shuffle(self.pieces_positions)
        
        # Фрейм для пазла
        self.puzzle_frame = ctk.CTkFrame(self, fg_color="transparent")
        self.puzzle_frame.pack(pady=10)
        
        # Создаем кнопки-фрагменты
        self.piece_buttons = []
        self.piece_images = []
        
        for i in range(4):
            row, col = divmod(i, 2)
            # Создаем изображение для фрагмента
            piece_img = self.create_piece_image(original, row, col)
            self.piece_images.append(piece_img)
            
            btn = ctk.CTkButton(
                self.puzzle_frame,
                image=piece_img,
                text="",
                width=200,
                height=200,
                command=lambda idx=i: self.select_piece(idx)
            )
            btn.grid(row=row, column=col, padx=2, pady=2)
            self.piece_buttons.append(btn)
        
        # Индикатор выбранного фрагмента
        self.selected_label = ctk.CTkLabel(
            self,
            text="Ничего не выбрано",
            font=ctk.CTkFont(size=12),
            text_color="orange"
        )
        self.selected_label.pack(pady=5)
    
    def create_piece_image(self, original, row, col):
        """Создание изображения для фрагмента"""
        w, h = 200, 200
        left = col * w
        top = row * h
        right = left + w
        bottom = top + h
        piece = original.crop((left, top, right, bottom))
        return ImageTk.PhotoImage(piece)
    
    def create_default_image(self):
        """Создание изображения-заглушки с цветными квадратами"""
        img = Image.new('RGB', (400, 400), color='white')
        from PIL import ImageDraw
        draw = ImageDraw.Draw(img)
        
        # Рисуем простой паттерн для пазла
        colors = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4']
        for i, color in enumerate(colors):
            row, col = divmod(i, 2)
            draw.rectangle([col*200, row*200, (col+1)*200, (row+1)*200], fill=color)
            draw.text([col*200+70, row*200+90], str(i+1), fill='white', size=40)
        
        img.save(self.image_path)
    
    def select_piece(self, idx):
        """Выбор фрагмента для перемещения"""
        self.selected_piece = idx
        self.selected_label.configure(text=f"Выбран фрагмент {idx + 1}")
        
        # Визуальное выделение выбранной кнопки
        for i, btn in enumerate(self.piece_buttons):
            if i == idx:
                btn.configure(fg_color="#359A85", border_width=2, border_color="yellow")
            else:
                btn.configure(fg_color="transparent", border_width=0)
    
    def swap_pieces(self, idx1, idx2):
        """Обмен фрагментов местами"""
        if idx1 is None or idx2 is None:
            return
        
        # Обмен позициями
        pos1 = self.pieces_positions[idx1]
        pos2 = self.pieces_positions[idx2]
        self.pieces_positions[idx1] = pos2
        self.pieces_positions[idx2] = pos1
        
        # Обновление сетки
        self.redraw_puzzle()
    
    def redraw_puzzle(self):
        """Перерисовка пазла с новыми позициями"""
        # Обновляем изображения кнопок
        pass  # В реальной реализации потребуется перегенерация изображений
    
    def check_puzzle(self):
        """Проверка правильности сборки пазла"""
        is_correct = self.pieces_positions == self.correct_positions
        
        if is_correct:
            self.callback(True)
            self.destroy()
        else:
            self.callback(False)
            self.destroy()


class SimpleCaptcha(ctk.CTkToplevel):
    """Упрощенная капча для экзамена (числовая, если пазл сложно реализовать)"""
    
    def __init__(self, parent, callback):
        super().__init__(parent)
        self.callback = callback
        
        self.title("Капча")
        self.geometry("300x250")
        self.resizable(False, False)
        self.grab_set()
        
        # Генерируем случайное выражение
        import random
        self.num1 = random.randint(1, 10)
        self.num2 = random.randint(1, 10)
        self.operation = random.choice(['+', '-'])
        
        if self.operation == '-':
            # Чтобы результат был положительным
            self.num1, self.num2 = max(self.num1, self.num2), min(self.num1, self.num2)
            self.correct_answer = self.num1 - self.num2
        else:
            self.correct_answer = self.num1 + self.num2
        
        # Интерфейс
        ctk.CTkLabel(self, text="Решите пример для продолжения:", 
                    font=ctk.CTkFont(size=14)).pack(pady=15)
        
        self.question = ctk.CTkLabel(
            self, 
            text=f"{self.num1} {self.operation} {self.num2} = ?",
            font=ctk.CTkFont(size=24, weight="bold")
        )
        self.question.pack(pady=10)
        
        self.answer_entry = ctk.CTkEntry(self, width=100, justify="center", font=ctk.CTkFont(size=18))
        self.answer_entry.pack(pady=10)
        self.answer_entry.bind("<Return>", lambda e: self.check())
        
        ctk.CTkButton(self, text="Проверить", command=self.check, fg_color="#359A85").pack(pady=10)
        
        # Фокус на поле ввода
        self.answer_entry.focus()
    
    def check(self):
        try:
            answer = int(self.answer_entry.get())
            self.callback(answer == self.correct_answer)
            self.destroy()
        except ValueError:
            self.callback(False)
            self.destroy()
