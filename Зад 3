    conn.commit()
    conn.close()
    print("✅ База данных users.db инициализирована")

def authenticate_user(username: str, password: str) -> tuple:
    """
    Аутентификация пользователя с проверкой блокировки
    Возвращает: (успех, сообщение, роль, id_пользователя)
    """
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT id, password_hash, role, is_blocked, failed_attempts
        FROM users WHERE username = ?
    ''', (username,))
    user = cursor.fetchone()
    
    if not user:
        conn.close()
        return (False, "Пользователь не найден", None, None)
    
    user_id, hashed, role, is_blocked, failed_attempts = user
    
    if is_blocked:
        conn.close()
        return (False, "Вы заблокированы. Обратитесь к администратору", None, None)
    
    if bcrypt.checkpw(password.encode('utf-8'), hashed):
        # Сброс счетчика попыток при успешном входе
        cursor.execute("UPDATE users SET failed_attempts = 0 WHERE id = ?", (user_id,))
        conn.commit()
        conn.close()
        return (True, "Вы успешно авторизовались", role, user_id)
    else:
        # Увеличиваем счетчик неудачных попыток
        failed_attempts += 1
        if failed_attempts >= 3:
            cursor.execute("UPDATE users SET failed_attempts = ?, is_blocked = 1 WHERE id = ?",
                          (failed_attempts, user_id))
            conn.commit()
            conn.close()
            return (False, "Превышено количество попыток. Аккаунт заблокирован", None, None)
        else:
            cursor.execute("UPDATE users SET failed_attempts = ? WHERE id = ?",
                          (failed_attempts, user_id))
            conn.commit()
            conn.close()
            return (False, f"Неверный пароль. Осталось попыток: {3 - failed_attempts}", None, None)

def add_user(username: str, password: str, role: str = 'user') -> tuple:
    """Добавление нового пользователя (только для администратора)"""
    if not username or not password:
        return (False, "Логин и пароль не могут быть пустыми")
    
    if len(password) < 4:
        return (False, "Пароль должен содержать минимум 4 символа")
    
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    
    # Проверка на существование
    cursor.execute("SELECT id FROM users WHERE username = ?", (username,))
    if cursor.fetchone():
        conn.close()
        return (False, "Пользователь с таким логином уже существует")
    
    hashed = bcrypt.hashpw(password.encode('utf-8'), bcrypt.gensalt())
    cursor.execute('''
        INSERT INTO users (username, password_hash, role)
        VALUES (?, ?, ?)
    ''', (username, hashed, role))
    
    conn.commit()
    conn.close()
    return (True, "Пользователь успешно добавлен")

def update_user(user_id: int, **kwargs) -> tuple:
    """Обновление данных пользователя (снятие блокировки, смена роли и т.д.)"""
    allowed_fields = ['username', 'role', 'is_blocked', 'failed_attempts']
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    
    for field, value in kwargs.items():
        if field in allowed_fields:
            cursor.execute(f"UPDATE users SET {field} = ? WHERE id = ?", (value, user_id))
    
    conn.commit()
    conn.close()
    return (True, "Данные пользователя обновлены")

def get_all_users():
    """Получение списка всех пользователей (для панели администратора)"""
    conn = sqlite3.connect(USERS_DB)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    
    cursor.execute("SELECT id, username, role, is_blocked, failed_attempts, created_at FROM users")
    users = cursor.fetchall()
    conn.close()
    
    return [dict(user) for user in users]

def unblock_user(user_id: int) -> tuple:
    """Снятие блокировки с пользователя"""
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET is_blocked = 0, failed_attempts = 0 WHERE id = ?", (user_id,))
    conn.commit()
    conn.close()
    return (True, "Пользователь разблокирован")

