    ''')
    
    # Создание администратора по умолчанию (логин: admin, пароль: admin)
    hashed_admin = bcrypt.hashpw('admin'.encode('utf-8'), bcrypt.gensalt())
    try:
        cursor.execute('''
            INSERT INTO users (username, password_hash, role)
            VALUES (?, ?, ?)
        ''', ('admin', hashed_admin, 'admin'))
    except sqlite3.IntegrityError:
        pass
    
    # Создание тестового пользователя
