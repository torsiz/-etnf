import customtkinter as ctk
from tkinter import messagebox
from database import get_product_by_id, save_order

def open_cart(parent, user_id, cart_items, clear_cart_callback):
    """Окно корзины с таблицей товаров, итоговой суммой и оформлением заказа."""
    cart_window = ctk.CTkToplevel(parent)
    cart_window.title("Корзина — ТехноМаркет")
    cart_window.geometry("800x500")
    cart_window.grab_set()  # Модальное окно
    
    # Шапка
    header = ctk.CTkFrame(cart_window, height=50, corner_radius=0)
    header.pack(fill="x")
    ctk.CTkLabel(header, text="Корзина", font=ctk.CTkFont(size=20, weight="bold")).pack(pady=10)
    
    # Фрейм для таблицы (скроллируемый)
    table_frame = ctk.CTkScrollableFrame(cart_window, corner_radius=10)
    table_frame.pack(fill="both", expand=True, padx=20, pady=10)
    
    # Заголовки таблицы
    headers = ["Товар", "Описание", "Цена", "Кол-во", "Сумма", ""]
    for i, header in enumerate(headers):
        lbl = ctk.CTkLabel(table_frame, text=header, font=ctk.CTkFont(weight="bold"), width=120)
        lbl.grid(row=0, column=i, padx=5, pady=5, sticky="w")
    
    rows = []
    total_sum = 0
    
    # Заполнение таблицы
    for idx, (product_id, quantity, price) in enumerate(cart_items):
        product = get_product_by_id(product_id)
        if not product:
            continue
        name = product['name']
        desc = product['description'][:30]
        item_sum = price * quantity
        total_sum += item_sum
        
        # Название
        ctk.CTkLabel(table_frame, text=name).grid(row=idx+1, column=0, padx=5, pady=2, sticky="w")
        # Описание
        ctk.CTkLabel(table_frame, text=desc).grid(row=idx+1, column=1, padx=5, pady=2, sticky="w")
        # Цена за единицу
        ctk.CTkLabel(table_frame, text=f"{price:.2f} ₽").grid(row=idx+1, column=2, padx=5, pady=2, sticky="e")
        # Количество (можно редактировать, но для простоты — метка)
        ctk.CTkLabel(table_frame, text=str(quantity)).grid(row=idx+1, column=3, padx=5, pady=2, sticky="e")
        # Сумма
        ctk.CTkLabel(table_frame, text=f"{item_sum:.2f} ₽").grid(row=idx+1, column=4, padx=5, pady=2, sticky="e")
        
        # Кнопка удаления
        def make_delete_func(idx_to_del):
            return lambda: delete_item(idx_to_del)
        
        del_btn = ctk.CTkButton(table_frame, text="Удалить", width=60, height=25, 
                               command=make_delete_func(idx))
        del_btn.grid(row=idx+1, column=5, padx=5, pady=2)
        rows.append(del_btn)
    
    def delete_item(row_index):
        """Удаление товара из корзины и обновление окна."""
        del cart_items[row_index]
        cart_window.destroy()
        open_cart(parent, user_id, cart_items, clear_cart_callback)
    
    # Нижняя панель с суммой и кнопками
    bottom_frame = ctk.CTkFrame(cart_window, height=60)
    bottom_frame.pack(fill="x", side="bottom", padx=20, pady=10)
    
    total_label = ctk.CTkLabel(bottom_frame, text=f"Общая сумма заказов: {total_sum:.2f} ₽", 
                               font=ctk.CTkFont(size=16, weight="bold"))
    total_label.pack(side="left", padx=10)
    
    def clear_cart():
        if messagebox.askyesno("Очистка", "Вы уверены, что хотите очистить корзину?"):
            cart_items.clear()
            cart_window.destroy()
            clear_cart_callback()
    
    def checkout():
        if messagebox.askyesno("Оформление", "Подтвердить заказ?"):
            # Сохранение заказа в БД
            if save_order(user_id, cart_items):
                messagebox.showinfo("Успех", "Заказ оформлен! Спасибо за покупку!")
                cart_items.clear()
                cart_window.destroy()
                clear_cart_callback()
            else:
                messagebox.showerror("Ошибка", "Не удалось сохранить заказ")
    
    clear_btn = ctk.CTkButton(bottom_frame, text="Очистить корзину", command=clear_cart, fg_color="gray")
    clear_btn.pack(side="right", padx=10)
    
    order_btn = ctk.CTkButton(bottom_frame, text="Оформить заказ", command=checkout, fg_color="#359A85")
    order_btn.pack(side="right", padx=10)





