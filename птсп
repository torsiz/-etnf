class ProductCard(ctk.CTkFrame):
    """Виджет карточки товара (плитка)."""
    def __init__(self, master, product_data, add_to_cart_callback, **kwargs):
        super().__init__(master, **kwargs)
        self.product_data = product_data
        self.add_to_cart_callback = add_to_cart_callback
        self.configure(corner_radius=10, border_width=1, border_color="gray70")
        
        # Контейнер для левой части (изображение)
        self.image_frame = ctk.CTkFrame(self, width=80, height=80, fg_color="transparent")
        self.image_frame.pack(side="left", padx=10, pady=10)
        self.image_frame.pack_propagate(False)
        
        # Загрузка изображения или заглушки
        image_path = f"assets/{product_data['image_path']}" if product_data['image_path'] else "assets/default.png"
        if not os.path.exists(image_path):
            image_path = "assets/default.png"
        
        try:
            img = Image.open(image_path)
            img = img.resize((70, 70), Image.Resampling.LANCZOS)
            self.photo = ctk.CTkImage(light_image=img, dark_image=img, size=(70, 70))
            self.image_label = ctk.CTkLabel(self.image_frame, image=self.photo, text="")
            self.image_label.pack(expand=True)
        except:
            self.image_label = ctk.CTkLabel(self.image_frame, text="Нет фото", font=("Arial", 10))
            self.image_label.pack(expand=True)
        
        # Центральная часть (название + описание)
        self.info_frame = ctk.CTkFrame(self, fg_color="transparent")
        self.info_frame.pack(side="left", fill="both", expand=True, padx=10, pady=10)
        
        self.name_label = ctk.CTkLabel(self.info_frame, text=product_data['name'], 
                                       font=ctk.CTkFont(size=14, weight="bold"), anchor="w")
        self.name_label.pack(anchor="w")
        
        self.desc_label = ctk.CTkLabel(self.info_frame, text=product_data['description'][:50] + "...", 
                                       font=ctk.CTkFont(size=11), anchor="w")
        self.desc_label.pack(anchor="w", pady=(5, 0))
        
        # Правая часть (цена)
        self.price_frame = ctk.CTkFrame(self, fg_color="transparent")
        self.price_frame.pack(side="right", padx=10, pady=10)
        
        final_price = product_data['price'] * (1 - product_data['discount'] / 100)
        
        self.current_price = ctk.CTkLabel(self.price_frame, text=f"{final_price:.2f} ₽", 
                                          font=ctk.CTkFont(size=16, weight="bold"), text_color="#359A85")
        self.current_price.pack(anchor="e")
        
        if product_data['discount'] > 0:
            self.old_price = ctk.CTkLabel(self.price_frame, text=f"{product_data['price']:.2f} ₽", 
                                          font=ctk.CTkFont(size=11), text_color="gray")
            self.old_price.pack(anchor="e")
            # Перечеркивание (имитация)
            self.old_price.configure(text_color_disabled="gray")
    
    def highlight(self, color="#359A85"):
        """Подсветка карточки при выборе."""
        self.configure(border_color=color, border_width=2)
    
    def unhighlight(self):
        """Сброс подсветки."""
        self.configure(border_color="gray70", border_width=1)

class MainApp(ctk.CTk):
    def __init__(self, user_id):
        super().__init__()
        
        self.user_id = user_id
        self.cart = []  # Список кортежей (product_id, quantity, price_at_time)
        self.selected_product_id = None
        self.current_theme = "light"  # 'light' или 'dark'
        
        # Настройка окна
        self.title("Магазин электроники — ООО 'ТехноМаркет'")
        self.geometry("1200x700")
        self.minsize(900, 500)
        
        # Инициализация БД
        init_db()
        
        # Создание интерфейса
        self.create_header()
        self.create_filter_bar()
        self.create_products_area()
        self.create_footer()
        
        # Загрузка товаров
        self.load_products()
        
        # Привязка обработчиков
        self.bind("<Configure>", self.on_resize)
    
    def create_header(self):
        """Создание шапки приложения (логотип, переключение темы)."""
        self.header_frame = ctk.CTkFrame(self, height=60, corner_radius=0)
        self.header_frame.pack(fill="x", pady=(0, 10))
        self.header_frame.pack_propagate(False)
        
        # Логотип по центру
        self.logo_label = ctk.CTkLabel(self.header_frame, text="ТЕХНОМАРКЕТ", 
                                       font=ctk.CTkFont(size=24, weight="bold"), text_color="#359A85")
        self.logo_label.pack(side="left", expand=True)
        
        # Кнопка переключения темы справа
        self.theme_btn = ctk.CTkButton(self.header_frame, text="🌙", width=40, 
                                       command=self.toggle_theme)
        self.theme_btn.pack(side="right", padx=20)
    
    def create_filter_bar(self):
        """Панель поиска и фильтрации."""
        self.filter_frame = ctk.CTkFrame(self, fg_color="transparent")
        self.filter_frame.pack(fill="x", padx=20, pady=(0, 10))
        
        self.search_entry = ctk.CTkEntry(self.filter_frame, placeholder_text="Поиск по названию или описанию...", width=300)
        self.search_entry.pack(side="left", padx=(0, 10))
        
        self.sort_option = ctk.CTkOptionMenu(self.filter_frame, 
                                             values=["Без сортировки", "от 0% до 14.99%", "от 15% до 24.99%", "более 25%"],
                                             width=200)
        self.sort_option.pack(side="left", padx=(0, 10))
        self.sort_option.set("Без сортировки")
        
        self.search_btn = ctk.CTkButton(self.filter_frame, text="Найти", command=self.load_products, width=100)
        self.search_btn.pack(side="left")
    
    def create_products_area(self):
        """Область со скроллируемым списком товаров."""
        self.products_container = ctk.CTkScrollableFrame(self, label_text="Каталог товаров")
        self.products_container.pack(fill="both", expand=True, padx=20, pady=(0, 10))
    
    def create_footer(self):
        """Нижняя панель со счетчиком товаров и кнопкой корзины."""
        self.footer_frame = ctk.CTkFrame(self, height=50, corner_radius=0)
        self.footer_frame.pack(fill="x", side="bottom")
        self.footer_frame.pack_propagate(False)
        
        self.counter_label = ctk.CTkLabel(self.footer_frame, text="Показано 0 из 0 товаров", font=ctk.CTkFont(size=12))
        self.counter_label.pack(side="left", padx=20)
        
        self.cart_btn = ctk.CTkButton(self.footer_frame, text="🛒 Корзина (0)", command=self.open_cart_window, 
                                      width=150, fg_color="#359A85", hover_color="#2A6F5F")
        self.cart_btn.pack(side="right", padx=20)
    
    def load_products(self):
        """Загрузка товаров из БД с применением фильтров и отображение в виде карточек."""
        # Очистка старых карточек
        for widget in self.products_container.winfo_children():
            widget.destroy()
        
        search_text = self.search_entry.get()
        filter_value = self.sort_option.get()
        
        products = get_products(search_text, filter_value)
        
        # Отображение счетчика
        self.counter_label.configure(text=f"Показано {len(products)} из {len(products)} товаров")
        
        # Создание карточек в сетке
        row = 0
        col = 0
        max_cols = 3
        
        for product in products:
            card = ProductCard(self.products_container, product, self.add_to_cart, 
                               width=350, height=120)
            card.grid(row=row, column=col, padx=10, pady=10, sticky="nsew")
            
            # Привязка событий для выбора карточки
            card.bind("<Button-1>", lambda e, p=product['id']: self.select_product(p))
            for child in card.winfo_children():
                child.bind("<Button-1>", lambda e, p=product['id']: self.select_product(p))
            
            # Привязка контекстного меню (правая кнопка мыши)
            card.bind("<Button-3>", lambda e, p=product: self.show_context_menu(e, p))
            for child in card.winfo_children():
                child.bind("<Button-3>", lambda e, p=product: self.show_context_menu(e, p))
            
            col += 1
            if col >= max_cols:
                col = 0
                row += 1
        
        # Настройка весов колонок для равномерного распределения
        for i in range(max_cols):
            self.products_container.grid_columnconfigure(i, weight=1)
    
    def select_product(self, product_id):
        """Выделение выбранного товара."""
        self.selected_product_id = product_id
        # Сброс подсветки у всех карточек
        for widget in self.products_container.winfo_children():
            if isinstance(widget, ProductCard):
                widget.unhighlight()
        # Подсветка выбранной (ищем по ID в данных)
        for widget in self.products_container.winfo_children():
            if isinstance(widget, ProductCard) and widget.product_data['id'] == product_id:
                # Определяем цвет темы
                theme_color = "#359A85" if self.current_theme == "light" else "#fcb2b2"
                widget.highlight(theme_color)
                break
    
    def show_context_menu(self, event, product):
        """Отображение контекстного меню (правый клик)."""
        menu = ctk.CTkMenu(master=self, tearoff=False)
        menu.add_command(label="Обновить", command=self.load_products)
        menu.add_command(label="Добавить в корзину", command=lambda: self.add_to_cart(product))
        menu.post(event.x_root, event.y_root)
    
    def add_to_cart(self, product_data):
        """Добавление товара в корзину."""
        product_id = product_data['id']
        final_price = product_data['price'] * (1 - product_data['discount'] / 100)
        
        # Проверка, есть ли уже такой товар в корзине
        for i, (pid, qty, price) in enumerate(self.cart):
            if pid == product_id:
                self.cart[i] = (pid, qty + 1, price)
                break
        else:
            self.cart.append((product_id, 1, final_price))
        
        # Обновление счетчика на кнопке корзины
        total_items = sum(qty for _, qty, _ in self.cart)
        self.cart_btn.configure(text=f"🛒 Корзина ({total_items})")
        
        messagebox.showinfo("Корзина", f"Товар '{product_data['name']}' добавлен в корзину")
    
    def open_cart_window(self):
        """Открытие окна корзины."""
        if not self.cart:
            messagebox.showinfo("Корзина", "Корзина пуста")
            return
        open_cart(self, self.user_id, self.cart, self.clear_cart_callback)
    
    def clear_cart_callback(self):
        """Callback для очистки корзины после оформления заказа."""
        self.cart = []
        total_items = 0
        self.cart_btn.configure(text=f"🛒 Корзина ({total_items})")
    
    def toggle_theme(self):
        """Переключение цветовой темы приложения."""
        if self.current_theme == "light":
            ctk.set_appearance_mode("Dark")
            self.current_theme = "dark"
            self.theme_btn.configure(text="☀️")
        else:
            ctk.set_appearance_mode("Light")
            self.current_theme = "light"
            self.theme_btn.configure(text="🌙")
    
    def on_resize(self, event):
        """Адаптивная подстройка размера карточек (простейшая)."""
        width = event.width
        if width < 1000:
            # Можно изменить кол-во колонок, но для простоты пропустим
            pass

def show_login():
    """Окно авторизации и регистрации."""
    login_window = ctk.CTk()
    login_window.title("Авторизация — ТехноМаркет")
    login_window.geometry("400x500")
    login_window.resizable(False, False)
    
    # Центрирование окна
    login_window.update_idletasks()
    x = (login_window.winfo_screenwidth() // 2) - (400 // 2)
    y = (login_window.winfo_screenheight() // 2) - (500 // 2)
    login_window.geometry(f"400x500+{x}+{y}")
    
    # Фрейм для формы
    frame = ctk.CTkFrame(login_window, corner_radius=20)
    frame.pack(expand=True, fill="both", padx=30, pady=30)
    
    ctk.CTkLabel(frame, text="Добро пожаловать", font=ctk.CTkFont(size=24, weight="bold")).pack(pady=(30, 20))
    
    # Поля ввода
    username_entry = ctk.CTkEntry(frame, placeholder_text="Логин", width=250)
    username_entry.pack(pady=10)
    
    password_entry = ctk.CTkEntry(frame, placeholder_text="Пароль", show="*", width=250)
    password_entry.pack(pady=10)
    
    status_label = ctk.CTkLabel(frame, text="", font=ctk.CTkFont(size=12))
    status_label.pack(pady=5)
    
    def do_login():
        username = username_entry.get()
        password = password_entry.get()
        success, msg, user_id = authenticate_user(username, password)
        if success:
            status_label.configure(text=msg, text_color="green")
            login_window.destroy()
            app = MainApp(user_id)
            app.mainloop()
        else:
            status_label.configure(text=msg, text_color="red")
    
    def do_register():
        username = username_entry.get()
        password = password_entry.get()
        if not username or not password:
            status_label.configure(text="Заполните все поля", text_color="red")
            return
        if register_user(username, password):
            status_label.configure(text="Регистрация успешна! Теперь войдите.", text_color="green")
            username_entry.delete(0, 'end')
            password_entry.delete(0, 'end')
