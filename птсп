import sqlite3
import bcrypt
from datetime import datetime
from typing import List, Tuple, Optional, Dict, Any

DATABASE_NAME = "store.db"

def init_db():
    """Инициализация базы данных: создание таблиц и тестовых данных."""
    conn = sqlite3.connect(DATABASE_NAME)
    cursor = conn.cursor()

    # Таблица пользователей
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password_hash TEXT NOT NULL,
            failed_attempts INTEGER DEFAULT 0,
            is_blocked BOOLEAN DEFAULT 0
        )
    ''')

    # Таблица товаров
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS products (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            description TEXT,
            price REAL NOT NULL,
            discount REAL DEFAULT 0,
            image_path TEXT
        )
    ''')

    # Таблица заказов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS orders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            total_sum REAL NOT NULL,
            order_date TEXT NOT NULL,
            FOREIGN KEY (user_id) REFERENCES users (id)
        )
    ''')

    # Таблица позиций заказа (связь многие-ко-многим)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS order_items (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_id INTEGER NOT NULL,
            product_id INTEGER NOT NULL,
            quantity INTEGER NOT NULL,
            price_at_time REAL NOT NULL,
            FOREIGN KEY (order_id) REFERENCES orders (id),
            FOREIGN KEY (product_id) REFERENCES products (id)
        )
    ''')

    # Заполнение тестовыми товарами, если таблица пуста
    cursor.execute("SELECT COUNT(*) FROM products")
    if cursor.fetchone()[0] == 0:
        test_products = [
            ("Игровая мышь Logitech", "Беспроводная мышь с RGB подсветкой", 4500.00, 15, "mouse.png"),
            ("Механическая клавиатура", "Red Switch, полная раскладка", 8500.00, 25, "keyboard.png"),
            ("Монитор 27\"", "IPS, 144Hz, 1ms", 22000.00, 10, "monitor.png"),
            ("Коврик для мыши", "Большой размер с подсветкой", 1200.00, 0, "pad.png"),
            ("USB Hub", "4 порта USB 3.0", 850.00, 5, "hub.png"),
        ]
        cursor.executemany("INSERT INTO products (name, description, price, discount, image_path) VALUES (?,?,?,?,?)", test_products)

    # Создание тестового пользователя для удобства (логин: admin, пароль: admin)
    hashed = bcrypt.hashpw("admin".encode('utf-8'), bcrypt.gensalt())
    try:
        cursor.execute("INSERT INTO users (username, password_hash) VALUES (?, ?)", ("admin", hashed))
    except sqlite3.IntegrityError:
        pass  # Пользователь уже существует

    conn.commit()
    conn.close()

def register_user(username: str, password: str) -> bool:
    """Регистрация нового пользователя с хешированием пароля."""
    try:
        hashed = bcrypt.hashpw(password.encode('utf-8'), bcrypt.gensalt())
        conn = sqlite3.connect(DATABASE_NAME)
        cursor = conn.cursor()
        cursor.execute("INSERT INTO users (username, password_hash) VALUES (?, ?)", (username, hashed))
        conn.commit()
        conn.close()
        return True
    except sqlite3.IntegrityError:
        return False  # Пользователь уже существует

def authenticate_user(username: str, password: str) -> Tuple[bool, str, Optional[int]]:
    """
    Аутентификация пользователя с проверкой блокировки.
    Возвращает: (Успех, Сообщение, ID_пользователя)
    """
    conn = sqlite3.connect(DATABASE_NAME)
    cursor = conn.cursor()
    
    # Получаем данные пользователя
    cursor.execute("SELECT id, password_hash, failed_attempts, is_blocked FROM users WHERE username = ?", (username,))
    user = cursor.fetchone()
    
    if not user:
        conn.close()
        return False, "Пользователь не найден", None
    
    user_id, hashed, attempts, blocked = user
    
    if blocked:
        conn.close()
        return False, "Учетная запись заблокирована. Обратитесь к администратору.", None
    
    # Проверка пароля
    if bcrypt.checkpw(password.encode('utf-8'), hashed):
        # Успешный вход: сброс счетчика попыток
        cursor.execute("UPDATE users SET failed_attempts = 0 WHERE id = ?", (user_id,))
        conn.commit()
        conn.close()
        return True, "Успешный вход", user_id
    else:
        # Неудачная попытка: инкремент счетчика
        attempts += 1
        if attempts >= 3:
            cursor.execute("UPDATE users SET failed_attempts = ?, is_blocked = 1 WHERE id = ?", (attempts, user_id))
            conn.commit()
            conn.close()
            return False, "Превышено количество попыток. Аккаунт заблокирован.", None
        else:
            cursor.execute("UPDATE users SET failed_attempts = ? WHERE id = ?", (attempts, user_id))
            conn.commit()
            conn.close()
            return False, f"Неверный пароль. Осталось попыток: {3 - attempts}", None

def get_products(search_term: str = "", discount_filter: str = "Без сортировки") -> List[Dict[str, Any]]:
    """
    Получение списка товаров с фильтрацией по поиску и скидке.
    discount_filter может быть: 'Без сортировки', 'от 0% до 14.99%', 'от 15% до 24.99%', 'более 25%'
    """
    conn = sqlite3.connect(DATABASE_NAME)
    conn.row_factory = sqlite3.Row  # Для доступа по имени колонки
    cursor = conn.cursor()
    
    query = "SELECT id, name, description, price, discount, image_path FROM products WHERE 1=1"
    params = []
    
    # Поиск по названию или описанию
    if search_term:
        query += " AND (name LIKE ? OR description LIKE ?)"
        params.extend([f"%{search_term}%", f"%{search_term}%"])
    
    # Фильтрация по скидке (применяется до сортировки)
    if discount_filter == "от 0% до 14.99%":
        query += " AND discount BETWEEN 0 AND 14.99"
    elif discount_filter == "от 15% до 24.99%":
        query += " AND discount BETWEEN 15 AND 24.99"
    elif discount_filter == "более 25%":
        query += " AND discount > 25"
    # "Без сортировки" — не добавляем условие
    
    # В задании сказано "Сортировка должна применяться только после нажатия", но по сути это фильтрация по диапазону
    # Просто выполняем запрос
    cursor.execute(query, params)
    products = [dict(row) for row in cursor.fetchall()]
    
    conn.close()
    return products

def get_product_by_id(product_id: int) -> Optional[Dict[str, Any]]:
    """Получение товара по ID."""
    conn = sqlite3.connect(DATABASE_NAME)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    cursor.execute("SELECT id, name, description, price, discount, image_path FROM products WHERE id = ?", (product_id,))
    product = cursor.fetchone()
    conn.close()
    return dict(product) if product else None

def save_order(user_id: int, cart_items: List[Tuple[int, int, float]]) -> bool:
    """
    Сохранение заказа в БД.
    cart_items: список кортежей (product_id, quantity, price_at_time)
    """
    try:
        conn = sqlite3.connect(DATABASE_NAME)
        cursor = conn.cursor()
        
        total_sum = sum(qty * price for _, qty, price in cart_items)
        order_date = datetime.now().isoformat()
        
        # Создаем заказ
        cursor.execute(
            "INSERT INTO orders (user_id, total_sum, order_date) VALUES (?, ?, ?)",
            (user_id, total_sum, order_date)
        )
        order_id = cursor.lastrowid
        
        # Сохраняем позиции
        for product_id, quantity, price in cart_items:
            cursor.execute(
                "INSERT INTO order_items (order_id, product_id, quantity, price_at_time) VALUES (?, ?, ?, ?)",
                (order_id, product_id, quantity, price)
            )
        
        conn.commit()
        conn.close()
        return True



