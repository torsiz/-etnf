🌐 Модуль 6: Валидация СНИЛС + API (1 час)

```python
import requests
import json
import customtkinter as ctk
from docx import Document

def validate_snils(snils):
    """Проверка СНИЛС по контрольной сумме"""
    snils = snils.replace("-", "").replace(" ", "")
    if not snils.isdigit() or len(snils) != 11:
        return False
    total = 0
    for i, digit in enumerate(snils[:9]):
        total += int(digit) * (9 - i)
    control = int(snils[9:])
    if total < 100:
        return total == control
    elif total == 100 or total == 101:
        return control == 0
    else:
        return (total % 101) == control

class ValidationApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("Валидация данных")
        self.geometry("600x400")
        
        # Подготовка ТестКейса
        self.doc = Document('ТестКейс.docx')
        self.table = self.doc.tables[0]
        
        # Интерфейс
        self.data_text = ctk.CTkTextbox(self, height=200)
        self.data_text.pack(pady=10, padx=10, fill="x")
        
        ctk.CTkButton(self, text="Получить данные", command=self.fetch_data).pack(pady=5)
        ctk.CTkButton(self, text="Отправить результат теста", command=self.send_result).pack(pady=5)
    
    def fetch_data(self):
        # Запрос к TransferSimulator.exe через HTTP
        response = requests.get("http://localhost:8080/api/get_data")
        data = response.json()
        self.data_text.delete("1.0", "end")
        self.data_text.insert("1.0", json.dumps(data, indent=2))
        
        # Заполняем ТестКейс
        self.table.cell(1, 0).text = "Валидация СНИЛС"
        self.table.cell(1, 1).text = "Проверка контрольной суммы"
        self.table.cell(1, 2).text = "СНИЛС корректен"  # ожидаемый результат
        # Закладка для результата
        self.table.cell(1, 3).text = ""  # сюда запишем результат после проверки
    
    def send_result(self):
        data = json.loads(self.data_text.get("1.0", "end"))
        snils = data.get('snils', '')
        is_valid = validate_snils(snils)
        
        # Записываем результат в ТестКейс
        self.table.cell(1, 3).text = "✅ Пройдено" if is_valid else "❌ Не пройдено"
        self.doc.save('ТестКейс.docx')
        
        # Отправляем результат в эмулятор
        response = requests.post("http://localhost:8080/api/send_result", 
                                json={"snils_valid": is_valid})
        self.show_result(is_valid)
    
    def show_result(self, valid):
        msg = "СНИЛС валиден" if valid else "СНИЛС невалиден"
        ctk.CTkLabel(self, text=msg, text_color="green" if valid else "red").pack()

if __name__ == "__main__":
    app = ValidationApp()
    app.mainloop()
```

