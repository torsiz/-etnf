🔐 Модуль 4: Авторизация + Пазл-капча + Роли (1 час)

Самый сложный модуль. Реализуем на Python + CustomTkinter.

```python
import customtkinter as ctk
import sqlite3
import bcrypt
import hashlib
import random
from PIL import Image, ImageTk
import tkinter as tk

# ---------- БД ----------
def init_auth_db():
    conn = sqlite3.connect('users.db')
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY,
            username TEXT UNIQUE,
            password_hash TEXT,
            role TEXT,
            is_blocked INTEGER DEFAULT 0,
            failed_attempts INTEGER DEFAULT 0
        )
    ''')
    # Админ по умолчанию: admin / admin
    hashed = bcrypt.hashpw('admin'.encode(), bcrypt.gensalt())
    cursor.execute('INSERT OR IGNORE INTO users (username, password_hash, role) VALUES (?, ?, ?)',
                   ('admin', hashed, 'admin'))
    conn.commit()
    conn.close()

# ---------- ПАЗЛ-КАПЧА ----------
class PuzzleCaptcha(ctk.CTkToplevel):
    def __init__(self, parent, callback):
        super().__init__(parent)
        self.callback = callback
        self.title("Соберите пазл")
        self.geometry("400x400")
        
        # Загружаем изображение и разрезаем на 4 части
        self.pieces = []
        self.selected = None
        
        img = Image.open("captcha_image.png")  # подготовьте картинку
        w, h = img.size
        piece_w, piece_h = w // 2, h // 2
        
        for i in range(2):
            for j in range(2):
                piece = img.crop((j*piece_w, i*piece_h, (j+1)*piece_w, (i+1)*piece_h))
                self.pieces.append(piece)
        
        random.shuffle(self.pieces)
        self.buttons = []
        for idx, piece in enumerate(self.pieces):
            photo = ImageTk.PhotoImage(piece.resize((100,100)))
            btn = ctk.CTkButton(self, image=photo, text="", width=100, height=100,
                               command=lambda i=idx: self.select_piece(i))
            btn.image = photo
            btn.grid(row=idx//2, column=idx%2, padx=5, pady=5)
            self.buttons.append(btn)
        
        ctk.CTkButton(self, text="Проверить", command=self.check).pack(pady=10)
    
    def select_piece(self, idx):
        self.selected = idx
    
    def check(self):
        # Проверяем порядок (для простоты - эталонный порядок)
        correct_order = [0,1,2,3]  # зависит от исходного порядка
        if self.selected == correct_order[0]:
            self.callback(True)
            self.destroy()
        else:
            self.callback(False)
            self.destroy()

# ---------- ГЛАВНОЕ ОКНО ----------
class LoginApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        init_auth_db()
        self.title("Авторизация")
        self.geometry("400x350")
        
        self.username = ctk.CTkEntry(self, placeholder_text="Логин")
        self.username.pack(pady=10)
        self.password = ctk.CTkEntry(self, placeholder_text="Пароль", show="*")
        self.password.pack(pady=10)
        
        self.captcha_status = False
        ctk.CTkButton(self, text="Пройти капчу (пазл)", command=self.open_captcha).pack(pady=5)
        ctk.CTkButton(self, text="Войти", command=self.login).pack(pady=10)
    
    def open_captcha(self):
        PuzzleCaptcha(self, self.captcha_result)
    
    def captcha_result(self, success):
        self.captcha_status = success
        if not success:
            self.increment_fails()
    
    def increment_fails(self):
        conn = sqlite3.connect('users.db')
        cursor = conn.cursor()
        username = self.username.get()
        cursor.execute("UPDATE users SET failed_attempts = failed_attempts + 1 WHERE username = ?", (username,))
        cursor.execute("UPDATE users SET is_blocked = 1 WHERE username = ? AND failed_attempts >= 3", (username,))
        conn.commit()
        conn.close()
    
    def login(self):
        username = self.username.get()
        password = self.password.get()
        
        conn = sqlite3.connect('users.db')
        cursor = conn.cursor()
        cursor.execute("SELECT password_hash, role, is_blocked FROM users WHERE username = ?", (username,))
        row = cursor.fetchone()
        conn.close()
        
        if not row:
            self.show_error()
            return
        
        hash_pw, role, blocked = row
        if blocked:
            self.show_error("Вы заблокированы. Обратитесь к администратору")
            return
        
        if not self.captcha_status:
            self.show_error("Пройдите капчу")
            return
        
        if bcrypt.checkpw(password.encode(), hash_pw):
            self.show_success("Вы успешно авторизовались")
            if role == 'admin':
                self.open_admin_panel()
            else:
                self.open_user_panel()
        else:
            self.show_error()
            self.increment_fails()
    
    def open_admin_panel(self):
        admin = ctk.CTkToplevel(self)
        admin.title("Панель администратора")
        admin.geometry("500x400")
        
        # Добавление пользователя
        ctk.CTkLabel(admin, text="Новый логин:").pack()
        new_login = ctk.CTkEntry(admin)
        new_login.pack()
        ctk.CTkLabel(admin, text="Пароль:").pack()
        new_pass = ctk.CTkEntry(admin, show="*")
        new_pass.pack()
        
        def add_user():
            conn = sqlite3.connect('users.db')
            cursor = conn.cursor()
            hashed = bcrypt.hashpw(new_pass.get().encode(), bcrypt.gensalt())
            try:
                cursor.execute("INSERT INTO users (username, password_hash, role) VALUES (?, ?, ?)",
                              (new_login.get(), hashed, 'user'))
                conn.commit()
            except:
                print("Пользователь уже существует")
            conn.close()
        
        ctk.CTkButton(admin, text="Добавить", command=add_user).pack(pady=5)
    
    def open_user_panel(self):
        user = ctk.CTkToplevel(self)
        user.title("Пользователь")
        user.geometry("300x200")
        ctk.CTkLabel(user, text="Добро пожаловать!").pack()
    
    def show_error(self, msg="Вы ввели неверный логин или пароль"):
        ctk.CTkLabel(self, text=msg, text_color="red").pack()
    
    def show_success(self, msg):
        ctk.CTkLabel(self, text=msg, text_color="green").pack()

if __name__ == "__main__":
    app = LoginApp()
    app.mainloop()
```

