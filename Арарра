def init_users_db():
    conn = sqlite3.connect("enterprise.db")
    cursor = conn.cursor()
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Пользователи (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            логин TEXT UNIQUE NOT NULL,
            пароль_hash TEXT NOT NULL,
            роль TEXT DEFAULT 'Пользователь',
            заблокирован BOOLEAN DEFAULT 0,
            попытки INTEGER DEFAULT 0
        )
    ''')
    
    # Создание админа по умолчанию
    admin_hash = bcrypt.hashpw("admin123".encode('utf-8'), bcrypt.gensalt())
    try:
        cursor.execute("INSERT INTO Пользователи (логин, пароль_hash, роль) VALUES (?, ?, 'Администратор')",
                      ("admin", admin_hash))
    except sqlite3.IntegrityError:
        pass
    
    conn.commit()
    conn.close()
    print("✅ Таблица пользователей готова")

# Функции работы с пользователями
def register_user(login, password, role="Пользователь"):
    try:
        hashed = bcrypt.hashpw(password.encode('utf-8'), bcrypt.gensalt())
        conn = sqlite3.connect("enterprise.db")
        cursor = conn.cursor()
        cursor.execute("INSERT INTO Пользователи (логин, пароль_hash, роль) VALUES (?, ?, ?)",
                      (login, hashed, role))
        conn.commit()
        conn.close()
        return True, "Пользователь добавлен"
    except sqlite3.IntegrityError:
        return False, "Логин уже существует"

def authenticate_user(login, password):
    conn = sqlite3.connect("enterprise.db")
    cursor = conn.cursor()
    cursor.execute("SELECT id, пароль_hash, роль, заблокирован, попытки FROM Пользователи WHERE логин = ?", (login,))
    user = cursor.fetchone()
    
    if not user:
        conn.close()
        return False, "Пользователь не найден", None, None
    
    user_id, hashed, role, blocked, attempts = user
    
    if blocked:
        conn.close()
        return False, "Вы заблокированы. Обратитесь к администратору", None, None
    
    if bcrypt.checkpw(password.encode('utf-8'), hashed):
        cursor.execute("UPDATE Пользователи SET попытки = 0 WHERE id = ?", (user_id,))
        conn.commit()
        conn.close()
        return True, "Вы успешно авторизовались", role, user_id
    else:
        attempts += 1
        if attempts >= 3:
            cursor.execute("UPDATE Пользователи SET заблокирован = 1, попытки = ? WHERE id = ?", (attempts, user_id))
            conn.commit()
            conn.close()
            return False, "Превышено количество попыток. Аккаунт заблокирован", None, None
        else:
            cursor.execute("UPDATE Пользователи SET попытки = ? WHERE id = ?", (attempts, user_id))
            conn.commit()
            conn.close()
            return False, f"Неверный пароль. Осталось попыток: {3 - attempts}", None, None

def get_all_users():
    conn = sqlite3.connect("enterprise.db")
    cursor = conn.cursor()
    cursor.execute("SELECT id, логин, роль, заблокирован FROM Пользователи")
    users = cursor.fetchall()
    conn.close()
    return users

def unblock_user(user_id):
    conn = sqlite3.connect("enterprise.db")
    cursor = conn.cursor()
    cursor.execute("UPDATE Пользователи SET заблокирован = 0, попытки = 0 WHERE id = ?", (user_id,))
    conn.commit()
    conn.close()

def update_user_role(user_id, new_role):
    conn = sqlite3.connect("enterprise.db")
    cursor = conn.cursor()
    cursor.execute("UPDATE Пользователи SET роль = ? WHERE id = ?", (new_role, user_id))
    conn.commit()
    conn.close()

# ========== КАПЧА-ПАЗЛ ==========
class PuzzleCaptcha(ctk.CTkFrame):
    def __init__(self, master, **kwargs):
        super().__init__(master, **kwargs)
        
        self.pieces = []  # Хранение фрагментов
        self.correct_order = []  # Правильный порядок
        self.current_order = []  # Текущий порядок
        
        self.create_puzzle()
    
    def create_puzzle(self):
        # Загрузка изображения и разбивка на 4 фрагмента (2x2)
        try:
            img = Image.open("puzzle_image.png").resize((200, 200))
        except:
            # Создаем тестовое изображение, если файла нет
            img = Image.new('RGB', (200, 200), color='lightblue')
        
        piece_size = 100
        self.correct_order = []
        
        for row in range(2):
            for col in range(2):
                piece = img.crop((col*piece_size, row*piece_size, 
                                 (col+1)*piece_size, (row+1)*piece_size))
                self.correct_order.append(piece)
        
        # Перемешиваем фрагменты
        self.current_order = self.correct_order.copy()
        random.shuffle(self.current_order)
        
        self.display_puzzle()
    
    def display_puzzle(self):
        # Очистка
        for widget in self.winfo_children():
            widget.destroy()
        
        ctk.CTkLabel(self, text="Соберите пазл:", font=ctk.CTkFont(size=12)).pack(pady=5)
        
        # Отображение фрагментов в сетке 2x2
        for i, piece in enumerate(self.current_order):
            row = i // 2
            col = i % 2
            
            # Конвертация в CTkImage
            ctk_img = ctk.CTkImage(light_image=piece, dark_image=piece, size=(90, 90))
            btn = ctk.CTkButton(self, image=ctk_img, text="", width=90, height=90,
                               command=lambda idx=i: self.swap_piece(idx))
            btn.grid(row=row, column=col, padx=5, pady=5)
    
    def swap_piece(self, idx):
        # Обмен с соседним фрагментом (простая логика)
        if idx < 3:
            self.current_order[idx], self.current_order[idx + 1] = \
                self.current_order[idx + 1], self.current_order[idx]
        else:
            self.current_order[idx], self.current_order[idx - 1] = \
                self.current_order[idx - 1], self.current_order[idx]
        
        self.display_puzzle()
    
    def verify(self):
        # Проверка правильности сборки
        for i in range(len(self.correct_order)):
            if self.current_order[i] != self.correct_order[i]:
                return False
        return True

