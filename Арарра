import customtkinter as ctk
import requests
import json
from docx import Document
import re

ctk.set_appearance_mode("Light")

class ValidationApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("Валидация данных клиентов")
        self.geometry("600x500")
        
        self.create_ui()
        self.current_data = None
    
    def create_ui(self):
        # Основной фрейм
        main_frame = ctk.CTkFrame(self, corner_radius=15)
        main_frame.pack(expand=True, fill="both", padx=20, pady=20)
        
        ctk.CTkLabel(main_frame, text="Валидация СНИЛС", 
                    font=ctk.CTkFont(size=20, weight="bold")).pack(pady=15)
        
        # Кнопка получения данных
        self.get_btn = ctk.CTkButton(main_frame, text="📥 Получить данные", 
                                    command=self.get_data, height=45)
        self.get_btn.pack(pady=10, fill="x")
        
        # Отображение данных
        self.data_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
        self.data_frame.pack(fill="both", expand=True, pady=15)
        
        self.name_label = ctk.CTkLabel(self.data_frame, text="ФИО: --", font=ctk.CTkFont(size=14))
        self.name_label.pack(anchor="w", pady=5)
        
        self.snils_label = ctk.CTkLabel(self.data_frame, text="СНИЛС: --", font=ctk.CTkFont(size=14))
        self.snils_label.pack(anchor="w", pady=5)
        
        self.result_label = ctk.CTkLabel(self.data_frame, text="Результат: ожидание", 
                                        font=ctk.CTkFont(size=14))
        self.result_label.pack(anchor="w", pady=5)
        
        # Кнопка отправки результата
        self.send_btn = ctk.CTkButton(main_frame, text="📤 Отправить результат теста", 
                                     command=self.validate_and_send, height=45,
                                     fg_color="#359A85", state="disabled")
        self.send_btn.pack(pady=10, fill="x")
    
    def get_data(self):
        """Получение данных из эмулятора TransferSimulator.exe"""
        try:
            # API эмулятора (порт и эндпоинт из api_info.pdf)
            response = requests.get("http://localhost:8080/api/get_data", timeout=5)
            
            if response.status_code == 200:
                self.current_data = response.json()
                self.name_label.configure(text=f"ФИО: {self.current_data.get('fio', 'Н/Д')}")
                self.snils_label.configure(text=f"СНИЛС: {self.current_data.get('snils', 'Н/Д')}")
                self.send_btn.configure(state="normal")
                self.result_label.configure(text="Результат: данные получены, ожидает проверки")
            else:
                self.result_label.configure(text=f"Ошибка: статус {response.status_code}", text_color="red")
        except Exception as e:
            self.result_label.configure(text=f"Ошибка подключения: {str(e)}", text_color="red")
    
    def validate_snils(self, snils: str) -> tuple:
        """
        Валидация СНИЛС по двум критериям:
        1. Формат: 123-456-789 01 или 12345678901
        2. Контрольная сумма
        """
        # Критерий 1: очистка от разделителей
        clean_snils = re.sub(r'\D', '', snils)
        
        if len(clean_snils) != 11:
            return False, "Неверная длина СНИЛС (должно быть 11 цифр)"
        
        if not clean_snils.isdigit():
            return False, "СНИЛС должен содержать только цифры"
        
        # Критерий 2: проверка контрольной суммы
        numbers = [int(d) for d in clean_snils[:9]]
        control = int(clean_snils[9:])
        
        # Алгоритм расчета контрольной суммы
        total = 0
        for i, num in enumerate(numbers):
            total += num * (9 - i)
        
        if total < 100:
            calculated = total
        elif total == 100:
            calculated = 0
        else:
            calculated = total % 101
            if calculated == 100:
                calculated = 0
        
        if calculated != control:
            return False, f"Неверная контрольная сумма (ожидается {calculated:02d}, получено {control:02d})"
        
        return True, "СНИЛС валиден"
    
    def validate_and_send(self):
        """Валидация и отправка результата"""
        if not self.current_data:
            self.result_label.configure(text="Сначала получите данные", text_color="orange")
            return
        
        snils = self.current_data.get('snils', '')
        is_valid, message = self.validate_snils(snils)
        
        # Обновление интерфейса
        if is_valid:
            self.result_label.configure(text=f"✅ Результат: {message}", text_color="green")
        else:
            self.result_label.configure(text=f"❌ Результат: {message}", text_color="red")
        
        # Отправка результата в API
        result_data = {
            "snils": snils,
            "is_valid": is_valid,
            "message": message,
            "timestamp": __import__('datetime').datetime.now().isoformat()
        }
        
        try:
            response = requests.post("http://localhost:8080/api/send_result", 
                                    json=result_data,
                                    timeout=5)
            if response.status_code == 200:
                print("Результат отправлен успешно")
        except Exception as e:
            print(f"Ошибка отправки: {e}")
        
        # Обновление ТестКейс.docx через python-docx
        self.update_test_case_doc(snils, is_valid, message)
    
    def update_test_case_doc(self, snils, is_valid, message):
        """Обновление документа ТестКейс.docx с результатом"""
        try:
            doc = Document("ТестКейс.docx")
            
            # Поиск строки с данным СНИЛС и добавление результата
            for table in doc.tables:
                for row in table.rows:
                    if snils in row.cells[1].text:  # Предполагаем, что СНИЛС во 2-й колонке
                        row.cells[3].text = "✅ Пройден" if is_valid else f"❌ {message}"
                        break
            
            doc.save("ТестКейс.docx")
            print("Документ ТестКейс.docx обновлен")
        except Exception as e:
            print(f"Ошибка обновления документа: {e}")

# Запуск
if __name__ == "__main__":
    app = ValidationApp()
    app.mainloop()
```

