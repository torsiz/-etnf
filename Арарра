⏱️ 30 минут

Что нужно сделать

1. Создать БД на основе ER-диаграммы из Модуля 1
2. Создать таблицы с атрибутами и ограничениями
3. Импортировать данные из файла "Заказчики.json"

🐍 Код для создания БД (SQLite)

```python
import sqlite3
import json

def create_database():
    conn = sqlite3.connect("enterprise.db")
    cursor = conn.cursor()
    
    # Таблица заказчиков (импорт из JSON)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Заказчики (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            фио TEXT NOT NULL,
            телефон TEXT,
            email TEXT UNIQUE
        )
    ''')
    
    # Таблица материалов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Материалы (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            название TEXT NOT NULL,
            стоимость REAL NOT NULL CHECK(стоимость >= 0)
        )
    ''')
    
    # Таблица продукции
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Продукция (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            название TEXT NOT NULL,
            цена REAL NOT NULL
        )
    ''')
    
    # Таблица спецификаций (связь продукция-материалы)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Спецификации (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            продукция_id INTEGER NOT NULL,
            материал_id INTEGER NOT NULL,
            норма_расхода REAL NOT NULL,
            FOREIGN KEY (продукция_id) REFERENCES Продукция(id) ON DELETE CASCADE,
            FOREIGN KEY (материал_id) REFERENCES Материалы(id) ON DELETE CASCADE,
            UNIQUE(продукция_id, материал_id)
        )
    ''')
    
    # Таблица заказов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Заказы (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            заказчик_id INTEGER NOT NULL,
            продукция_id INTEGER NOT NULL,
            количество INTEGER NOT NULL CHECK(количество > 0),
            дата_заказа TEXT DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (заказчик_id) REFERENCES Заказчики(id),
            FOREIGN KEY (продукция_id) REFERENCES Продукция(id)
        )
    ''')
    
    # Импорт заказчиков из JSON
    with open("Заказчики.json", "r", encoding="utf-8") as f:
        customers = json.load(f)
    
    for customer in customers:
        cursor.execute('''
            INSERT OR IGNORE INTO Заказчики (фио, телефон, email)
            VALUES (?, ?, ?)
        ''', (customer.get('фио'), customer.get('телефон'), customer.get('email')))
    
    conn.commit()
    conn.close()
    print("✅ База данных создана и заполнена")

if __name__ == "__main__":
    create_database()
```

