class AdminPanel(ctk.CTkToplevel):
    def __init__(self, parent):
        super().__init__(parent)
        self.title("Администрирование пользователей")
        self.geometry("600x400")
        
        self.create_ui()
        self.load_users()
    
    def create_ui(self):
        # Список пользователей
        self.users_listbox = ctk.CTkScrollableFrame(self, width=350)
        self.users_listbox.pack(side="left", fill="both", expand=True, padx=10, pady=10)
        
        # Панель действий
