                                      variable=self.role_var)
        role_menu.pack(pady=5)
        
        ctk.CTkButton(actions_frame, text="➕ Добавить", command=self.add_user).pack(pady=5)
        ctk.CTkButton(actions_frame, text="🔓 Разблокировать", command=self.unblock_user).pack(pady=5)
        ctk.CTkButton(actions_frame, text="🗑️ Удалить", command=self.delete_user, fg_color="red").pack(pady=5)
    
    def load_users(self):
        for widget in self.users_listbox.winfo_children():
            widget.destroy()
        
        users = get_all_users()
        self.user_buttons = []
        
        for user in users:
            user_id, login, role, blocked = user
            status = "🔒 Заблокирован" if blocked else "✅ Активен"
            btn = ctk.CTkButton(self.users_listbox, 
                               text=f"{login} [{role}] - {status}",
                               anchor="w", height=35,
                               command=lambda uid=user_id: self.select_user(uid))
            btn.pack(fill="x", pady=2)
            self.user_buttons.append((btn, user_id))
    
    def select_user(self, user_id):
        self.selected_user_id = user_id
    
    def add_user(self):
        login = self.add_login.get()
        password = self.add_pass.get()
        
        if not login or not password:
            messagebox.showerror("Ошибка", "Заполните все поля")
            return
        
        success, msg = register_user(login, password, self.role_var.get())
        if success:
            messagebox.showinfo("Успех", msg)
            self.load_users()
            self.add_login.delete(0, 'end')
            self.add_pass.delete(0, 'end')
        else:
            messagebox.showerror("Ошибка", msg)
    
    def unblock_user(self):
        if hasattr(self, 'selected_user_id'):
            unblock_user(self.selected_user_id)
            messagebox.showinfo("Успех", "Пользователь разблокирован")
            self.load_users()
    
    def delete_user(self):
        if hasattr(self, 'selected_user_id'):
            if messagebox.askyesno("Подтверждение", "Удалить пользователя?"):
                conn = sqlite3.connect("enterprise.db")
                cursor = conn.cursor()
                cursor.execute("DELETE FROM Пользователи WHERE id = ?", (self.selected_user_id,))
                conn.commit()
                conn.close()
                self.load_users()

