        actions_frame.pack(side="right", fill="y", padx=10, pady=10)
        
        ctk.CTkLabel(actions_frame, text="Действия", font=ctk.CTkFont(weight="bold")).pack(pady=5)
        
        self.add_login = ctk.CTkEntry(actions_frame, placeholder_text="Логин")
        self.add_login.pack(pady=5)
        
        self.add_pass = ctk.CTkEntry(actions_frame, placeholder_text="Пароль", show="*")
