        ctk.CTkLabel(frame, text="Вход в систему", font=ctk.CTkFont(size=24, weight="bold")).pack(pady=20)
        
        # Поля ввода
        self.login_entry = ctk.CTkEntry(frame, placeholder_text="Логин", width=250, height=40)
        self.login_entry.pack(pady=10)
        
        self.password_entry = ctk.CTkEntry(frame, placeholder_text="Пароль", show="*", width=250, height=40)
        self.password_entry.pack(pady=10)
        
        # Капча-пазл
        self.captcha = PuzzleCaptcha(frame)
        self.captcha.pack(pady=15)
        
        # Кнопка входа
        ctk.CTkButton(frame, text="Войти", command=self.do_login, 
                     width=200, height=40, fg_color="#359A85").pack(pady=20)
        
        # Статус
        self.status_label = ctk.CTkLabel(frame, text="", font=ctk.CTkFont(size=12))
        self.status_label.pack()
    
    def do_login(self):
        login = self.login_entry.get()
        password = self.password_entry.get()
        
        # Проверка обязательности полей
        if not login or not password:
            self.status_label.configure(text="Логин и пароль обязательны для заполнения", text_color="red")
            return
        
        # Проверка капчи
        if not self.captcha.verify():
            self.failed_attempts += 1
            if self.failed_attempts >= 3:
                messagebox.showerror("Блокировка", "Вы заблокированы. Обратитесь к администратору")
                self.destroy()
                return
            else:
                self.status_label.configure(text=f"Пазл собран неверно. Осталось попыток: {3 - self.failed_attempts}", 
                                          text_color="red")
                self.captcha.create_puzzle()  # Обновляем пазл
                return
        
        # Аутентификация
        success, msg, role, user_id = authenticate_user(login, password)
        
        if success:
            messagebox.showinfo("Успех", msg)
            self.destroy()
            app = MainWindow(user_id, login, role)
            app.mainloop()
        else:
            self.status_label.configure(text=msg, text_color="red")

# ========== ЗАПУСК ==========
if __name__ == "__main__":
    init_users_db()
    app = LoginWindow()
    app.mainloop()
